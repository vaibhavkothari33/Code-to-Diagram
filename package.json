{
  "name": "codesketch",
  "displayName": "CodeSketch",
  "description": "A powerful Visual Studio Code extension that generates interactive diagrams from your JavaScript, Python, and C++ code using D3.js visualization.",
  "publisher": "VaibhavKothari",
  "version": "1.5.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaibhavkothari33/Code-to-Diagram.git"
  },
  "icon": "logo.png",
  "activationEvents": [
    "onCommand:extension.codesketch"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.codesketch",
        "title": "CodeSketch"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "extension.codesketch",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npx tsc",
    "package": "npx vsce package",
    "publish": "npx vsce publish"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^14.0.0",
    "@types/vscode": "^1.60.0",
    "typescript": "^4.0.0"
  }
}
